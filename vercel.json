{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "docs/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/css/(.*)",
      "dest": "/docs/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "/docs/js/$1"
    },
    {
      "src": "/images/(.*)",
      "dest": "/docs/images/$1"
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}